+// Group Host cell: dropdown of same-teacher group students for picking whose
+// house the car drives to. Only shown for group-type students, otherwise "—".
+function groupHostCell(s){
+  if((s.sessionType||'1on1')!=='group') return '<span style="color:var(--text3);font-size:9px">—</span>';
+  // Collect all group-type students with the same teacher (excluding self)
+  const peers=Object.values(SS).filter(p=>p.id!==s.id&&p.t===s.t&&(p.sessionType||'1on1')==='group');
+  const host=s.groupHost||'';
+  let opts='<option value=""'+(host?'':' selected')+'>Self (own address)</option>';
+  peers.forEach(p=>{
+    opts+='<option value="'+p.id+'"'+(host===p.id?' selected':'')+'>'+esc(p.n)+'</option>';
+  });
+  return '<select class="st-sel" style="min-width:120px;font-size:9px" onchange="patchStudent(\''+s.id+'\',\'groupHost\',this.value)">'+opts+'</select>';
+}
+
+// Resolve the routing coordinates for a student. For group students with a
+// groupHost set, return the host student's lat/lng instead of their own.
+function resolveGroupCoords(s){
+  if(s.groupHost&&SS[s.groupHost]){
+    const h=SS[s.groupHost];
+    return {la:h.la,ln:h.ln};
+  }
+  return {la:s.la,ln:s.ln};
+}
