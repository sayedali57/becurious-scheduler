+  // Spread rule: students with 2+ sessions/week should have at least a 1-day
+  // gap between sessions. adjacentDays returns the days immediately before and
+  // after the given day in the active schedule (e.g., Mon → [Sun,Tue]).
+  function adjacentDays(day){
+    const idx=DAYS_ACTIVE.indexOf(day);if(idx<0)return[];
+    const adj=[];
+    if(idx>0)adj.push(DAYS_ACTIVE[idx-1]);
+    if(idx<DAYS_ACTIVE.length-1)adj.push(DAYS_ACTIVE[idx+1]);
+    return adj;
+  }
+  function isSpreadOk(sid,day){
+    const s=SS[sid];if(!s)return true;
+    if((s.sessionsPerWeek||1)<=1)return true; // only 1 session — no spread needed
+    return adjacentDays(day).every(ad=>!onDay[ad]?.has(sid));
+  }
+
   function candidateFor(day,car,pos,lastTeacher){
-    return Object.keys(remain).filter(sid=>{
+    // First pass: candidates that satisfy the spread rule (1-day gap)
+    const all=Object.keys(remain).filter(sid=>{
       if(remain[sid]<=0)return false;
       const s=SS[sid];if(!s)return false;
       if(preventDouble&&onDay[day].has(sid))return false;
       if(!carServesBranch(car,s))return false;
       if(!teacherCanTake(s.t,day))return false;
       return true;
-    }).sort((a,b)=>{
+    });
+    const spread=all.filter(sid=>isSpreadOk(sid,day));
+    // Use spread-compliant candidates first; fall back to all if none available
+    // (better to schedule back-to-back than not at all)
+    const pool=spread.length?spread:all;
+    return pool.sort((a,b)=>{
       const sa=SS[a],sb=SS[b];
       const chA=(lastTeacher&&sa.t===lastTeacher)?chainBonus:0;
       const chB=(lastTeacher&&sb.t===lastTeacher)?chainBonus:0;
@@ -4744,6 +4781,7 @@ function runAutoSchedule(){
             if(sid2===pickSid||remain[sid2]<=0)return false;
             const s2=SS[sid2];if(!s2)return false;
             if(preventDouble&&onDay[day].has(sid2))return false;
+            if(!isSpreadOk(sid2,day))return false;
             if(!carServesBranch(car,s2))return false;
             if(!teacherCanTake(s2.t,day))return false;
             return hv(pickS.la,pickS.ln,s2.la,s2.ln)<=0.5;
