+// Rejected days: compact row of clickable day pills — toggling a day marks it
+// as rejected by the parent. Red = rejected, grey = available.
+function rejectedDaysCells(s){
+  const days=['Sun','Mon','Tue','Wed','Thu'];
+  const rej=s.rejectedDays||[];
+  return '<div style="display:flex;gap:2px">'+days.map(d=>{
+    const on=rej.includes(d);
+    return '<span onclick="toggleRejDay(\''+s.id+'\',\''+d+'\')" style="cursor:pointer;font-size:8px;font-weight:600;padding:2px 5px;border-radius:4px;user-select:none;'
+      +(on?'background:#FEE2E2;color:#DC2626;border:1px solid #FECACA':'background:#F3F4F6;color:var(--text3);border:1px solid #E5E7EB')
+      +'" title="'+(on?d+': REJECTED by parent — click to allow':d+': allowed — click to reject')+'">'+d+'</span>';
+  }).join('')+'</div>';
+}
+function toggleRejDay(sid,day){
+  const s=SS[sid];if(!s)return;
+  if(!Array.isArray(s.rejectedDays))s.rejectedDays=[];
+  const idx=s.rejectedDays.indexOf(day);
+  if(idx>=0)s.rejectedDays.splice(idx,1); else s.rejectedDays.push(day);
+  saveState();renderStudentsTable();
+  const row=qs('strow-'+sid);
+  if(row){row.style.background='#EAF3DE';setTimeout(()=>row.style.background='',800);}
+}
+// Check if a student is on a rejected day
+function isRejectedDay(sid,day){
+  const s=SS[sid];if(!s)return false;
+  return Array.isArray(s.rejectedDays)&&s.rejectedDays.includes(day);
+}
