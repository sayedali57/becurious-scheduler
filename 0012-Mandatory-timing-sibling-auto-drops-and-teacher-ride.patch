+// Build compact mandatory-time editors for the students table. One row
+// per session: day dropdown + time input. Empty = flexible (parent ok
+// with any day/time). Filled = auto-scheduler must honour this slot.
+function mandatoryCells(s){
+  const spw=s.sessionsPerWeek||1;
+  const mand=s.mandatory||[];
+  const dayOpts=['Sun','Mon','Tue','Wed','Thu'];
+  let html='';
+  for(let m=0;m<spw;m++){
+    const e=mand[m]||{};
+    const dv=e.day||'';
+    const tv=e.min!=null?ts24(e.min):'';
+    html+=`<div style="display:flex;gap:2px;align-items:center;margin:${m?'2px':'0'} 0">
+      <span style="font-size:8px;color:var(--text3);width:10px">${m+1}.</span>
+      <select class="st-sel" style="width:50px;font-size:9px;padding:1px 2px" onchange="patchMandatory('${s.id}',${m},'day',this.value)">
+        <option value="">—</option>
+        ${dayOpts.map(d=>`<option${d===dv?' selected':''}>${d}</option>`).join('')}
+      </select>
+      <input type="time" value="${tv}" style="width:62px;font-size:9px;border:1px solid var(--border);border-radius:3px;padding:1px 2px" onchange="patchMandatory('${s.id}',${m},'min',this.value)">
+    </div>`;
+  }
+  return html;
+}
