+// Returns an HTML annotation banner when the driver needs to swap teachers
+// between consecutive drop slots. Tracks who was just dropped versus who is
+// about to be dropped: if the teacher changes, the driver must detour back to
+// the branch to return one teacher and pick up another.
+function teacherRideNote(d,cid,si){
+  const sl_=SCHED[d]?.[cid]?.[si];
+  if(!sl_||sl_.t==='pick')return'';
+  const curT=[...new Set(slotStudentIds(sl_).map(sid=>SS[sid]?.t).filter(Boolean))];
+  if(!curT.length)return'';
+  // Walk backwards to find the previous DROP slot (skip pickups)
+  let prevT=[];
+  for(let i=si-1;i>=0;i--){
+    const p=SCHED[d]?.[cid]?.[i];
+    if(p&&p.t!=='pick'){
+      prevT=[...new Set(slotStudentIds(p).map(sid=>SS[sid]?.t).filter(Boolean))];
+      break;
+    }
+  }
+  const br=carBranch(cid);
+  // No previous drop → first drop of the day. Show who the driver picks up.
+  if(!prevT.length){
+    return`<div class="ride-note">🚗 Pick up <b>${curT.join(' + ')}</b> from ${br} branch</div>`;
+  }
+  // Check for teacher change
+  const prevSet=new Set(prevT), curSet=new Set(curT);
+  const returning=[...prevSet].filter(t=>!curSet.has(t));
+  const pickingUp=[...curSet].filter(t=>!prevSet.has(t));
+  if(!returning.length&&!pickingUp.length)return''; // same teacher(s), no change
+  let note='🚗 ';
+  if(returning.length)note+=`↩ ${returning.join(' + ')} → ${br} branch`;
+  if(returning.length&&pickingUp.length)note+=' · ';
+  if(pickingUp.length)note+=`Pick up <b>${pickingUp.join(' + ')}</b> from ${br} branch`;
+  return`<div class="ride-note">${note}</div>`;
+}
