+function patchMandatory(sid,idx,field,val){
+  const s=SS[sid];if(!s)return;
+  if(!Array.isArray(s.mandatory))s.mandatory=[];
+  while(s.mandatory.length<=idx)s.mandatory.push(null);
+  if(field==='day'){
+    if(!val){s.mandatory[idx]=null;}
+    else{if(!s.mandatory[idx])s.mandatory[idx]={};s.mandatory[idx].day=val;}
+  }
+  if(field==='min'){
+    const mins=parseTime24(val);
+    if(mins==null){if(s.mandatory[idx])delete s.mandatory[idx].min;}
+    else{if(!s.mandatory[idx])s.mandatory[idx]={};s.mandatory[idx].min=mins;}
+  }
+  // Clean: remove trailing nulls / entries with neither day nor min
+  s.mandatory=s.mandatory.map(e=>e&&(e.day||e.min!=null)?e:null);
+  while(s.mandatory.length>0&&!s.mandatory[s.mandatory.length-1])s.mandatory.pop();
+  saveState();
+  const row=qs('strow-'+sid);
+  if(row){row.style.background='#EAF3DE';setTimeout(()=>row.style.background='',800);}
+}
