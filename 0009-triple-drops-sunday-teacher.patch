 // ===== TIMING =====
+// Multi-drop helpers: a 'd' slot holds 2 or 3 students in its `ids` array and
+// an optional `legs` array giving inter-home minutes between consecutive drops.
+// Legacy double-drops only store a single `inter` scalar, so ddLegs falls back
+// to computing from coords (or reading `inter`) when `legs` is absent. This
+// lets old saved schedules keep working after the triple-drop upgrade.
+function ddLegs(sl_){
+  if(!sl_||sl_.t!=='d'||!sl_.ids)return[];
+  if(Array.isArray(sl_.legs)&&sl_.legs.length===sl_.ids.length-1)return sl_.legs;
+  if(sl_.ids.length===2){
+    const s1=SS[sl_.ids[0]],s2=SS[sl_.ids[1]];
+    const inter=sl_.inter||(s1&&s2?tm(hv(s1.la,s1.ln,s2.la,s2.ln)):0);
+    return[inter];
+  }
+  const legs=[];
+  for(let i=0;i<sl_.ids.length-1;i++){
+    const a=SS[sl_.ids[i]],b=SS[sl_.ids[i+1]];
+    legs.push(a&&b?tm(hv(a.la,a.ln,b.la,b.ln)):0);
+  }
+  return legs;
+}
+function ddTotalInter(sl_){return ddLegs(sl_).reduce((a,b)=>a+b,0);}
+// Sum of straight-line km between consecutive homes. For legacy 2-student
+// drops with only `sl_.km` saved, prefer the stored value.
+function ddTotalKm(sl_){
+  if(!sl_||!sl_.ids)return 0;
+  if(sl_.ids.length===2&&sl_.km!=null)return sl_.km;
+  let total=0;
+  for(let i=0;i<sl_.ids.length-1;i++){
+    const a=SS[sl_.ids[i]],b=SS[sl_.ids[i+1]];
+    if(a&&b)total+=hv(a.la,a.ln,b.la,b.ln);
+  }
+  return total;
+}
+// Recompute legs + km + inter after an edit (add/remove student).
+function ddRecomputeMetrics(sl_){
+  if(!sl_||sl_.t!=='d'||!sl_.ids)return;
+  const legs=[];let totalKm=0;
+  for(let i=0;i<sl_.ids.length-1;i++){
+    const a=SS[sl_.ids[i]],b=SS[sl_.ids[i+1]];
+    if(a&&b){
+      const d=hv(a.la,a.ln,b.la,b.ln);
+      totalKm+=d;
+      legs.push(tm(d));
+    }else{
+      legs.push(0);
+    }
+  }
+  sl_.legs=legs;
+  sl_.km=totalKm;
+  sl_.inter=legs.reduce((a,b)=>a+b,0); // keep for back-compat (total minutes between first and last drop)
+}
