+// — TAB 4: Branch summary —
+function auditBranch(AD){
+  const branches=[...new Set(Object.values(SS).map(s=>s.br).filter(Boolean))].sort();
+  const rows=branches.map(br=>{
+    const brStudents=Object.values(SS).filter(s=>s.br===br);
+    const totalNeed=brStudents.reduce((a,s)=>a+(s.sessionsPerWeek||1),0);
+    const brCars=CARS.filter(c=>(c.branch||'').split('/').includes(br));
+    // Count scheduled sessions
+    let totalSched=0;
+    const dayStats={};
+    AD.forEach(d=>{
+      let daySched=0,daySlots=0,dayUsed=0;
+      brCars.forEach(car=>{
+        const slots=SCHED[d]?.[car.id]||[];
+        daySlots+=slots.length;
+        slots.forEach(sl_=>{
+          if(!sl_)return;
+          dayUsed++;
+          if(sl_.t==='pick')return;
+          slotStudentIds(sl_).forEach(sid=>{
+            if(SS[sid]?.br===br){daySched++;totalSched++;}
+          });
+        });
+      });
+      dayStats[d]={sched:daySched,slots:daySlots,used:dayUsed,capPct:daySlots>0?Math.round(dayUsed/daySlots*100):0};
+    });
+    // Teachers serving this branch
+    const brTeachers=[...new Set(brStudents.map(s=>s.t))];
+    // Unscheduled students
+    const schedSids=new Set();
+    AD.forEach(d=>CARS.forEach(car=>(SCHED[d]?.[car.id]||[]).forEach(sl_=>{
+      if(!sl_||sl_.t==='pick')return;
+      slotStudentIds(sl_).forEach(sid=>schedSids.add(sid));
+    })));
+    const unschedStudents=brStudents.filter(s=>{
+      const needed=s.sessionsPerWeek||1;
+      const got=countScheduled(s.id);
+      return got<needed;
+    });
+    const coveragePct=totalNeed>0?Math.round(totalSched/totalNeed*100):100;
+    return{br,brStudents,totalNeed,totalSched,brCars,dayStats,brTeachers,unschedStudents,coveragePct};
+  });
+
+  let h=`<div class="audit-summary">
+    <div class="audit-stat"><b>${branches.length}</b><small>Branches</small></div>
+    <div class="audit-stat"><b>${Object.values(SS).length}</b><small>Total students</small></div>
+    <div class="audit-stat"><b>${CARS.length}</b><small>Total cars</small></div>
+    <div class="audit-stat"><b style="color:${rows.every(r=>r.coveragePct>=95)?'#059669':'#D97706'}">${rows.length?Math.round(rows.reduce((a,r)=>a+r.coveragePct,0)/rows.length):100}%</b><small>Avg coverage</small></div>
+  </div>`;
+  h+=`<div style="max-height:65vh;overflow:auto"><table class="audit-tbl"><thead><tr>
+    <th>Branch</th><th>Students</th><th>Sessions needed</th><th>Scheduled</th><th>Coverage</th><th>Cars</th><th>Teachers</th>`;
+  AD.forEach(d=>h+=`<th>${d} cap</th>`);
+  h+=`<th>Unscheduled students</th></tr></thead><tbody>`;
+  rows.forEach(r=>{
+    const covCls=r.coveragePct>=95?'a-pill-green':r.coveragePct>=70?'a-pill-amber':'a-pill-red';
+    h+=`<tr><td><b>${r.br}</b></td><td>${r.brStudents.length}</td><td>${r.totalNeed}</td>
+      <td class="${r.totalSched>=r.totalNeed?'a-ok':'a-warn'}">${r.totalSched}</td>
+      <td><span class="a-pill ${covCls}">${r.coveragePct}%</span></td>
+      <td>${r.brCars.length} (${r.brCars.map(c=>c.label).join(', ')})</td>
+      <td style="font-size:9px">${r.brTeachers.join(', ')}</td>`;
+    AD.forEach(d=>{
+      const ds=r.dayStats[d];
+      const capCls=ds.capPct>=90?'a-bad':ds.capPct>=70?'a-warn':'a-ok';
+      h+=`<td class="${capCls}">${ds.used}/${ds.slots} (${ds.capPct}%)</td>`;
+    });
+    h+=`<td style="font-size:9px;color:#DC2626">${r.unschedStudents.length?r.unschedStudents.map(s=>s.n).join(', '):'<span class="a-ok">All covered</span>'}</td></tr>`;
+  });
+  h+=`</tbody></table></div>`;
+  return h;
+}
