+// ===== AUDIT VIEW =====
+let _auditTab='students';
+function switchView(view){
+  qs('vt-daily').classList.toggle('active',view==='daily');
+  qs('vt-audit').classList.toggle('active',view==='audit');
+  qs('sched-outer').style.display=view==='daily'?'':'none';
+  document.querySelectorAll('.legend').forEach(el=>el.style.display=view==='daily'?'':'none');
+  qs('audit-outer').style.display=view==='audit'?'block':'none';
+  if(view==='audit')renderAudit();
+}
+function switchAuditTab(tab){
+  _auditTab=tab;
+  document.querySelectorAll('.audit-tab').forEach(b=>b.classList.toggle('active',b.dataset.atab===tab));
+  renderAudit();
+}
+
+function renderAudit(){
+  // Populate branch dropdown
+  const brSel=qs('audit-branch');
+  const curBrVal=brSel.value;
+  const branches=['All',...new Set(Object.values(SS).map(s=>s.br).filter(Boolean))];
+  brSel.innerHTML=branches.map(b=>`<option${b===curBrVal?' selected':''}>${b==='All'?'All branches':b}</option>`).join('');
+  brSel.value=curBrVal&&branches.includes(curBrVal)?curBrVal:(branches.includes(curBrVal)?curBrVal:'All');
+  const filterBr=brSel.value==='All branches'?'All':brSel.value;
+
+  // Populate teacher dropdown based on branch
+  const tSel=qs('audit-teacher');
+  const curTVal=tSel.value;
+  let teachers=Object.keys(TEACHERS).filter(t=>TEACHERS[t].active!==0);
+  if(filterBr!=='All')teachers=teachers.filter(t=>{
+    const te=TEACHERS[t];return!te.branch||te.branch===filterBr;
+  });
+  teachers.sort();
+  tSel.innerHTML='<option>All teachers</option>'+teachers.map(t=>`<option${t===curTVal?' selected':''}>${t}</option>`).join('');
+  const filterT=tSel.value==='All teachers'?'All':tSel.value;
+
+  const AD=activeDays();
+  const body=qs('audit-body');
+
+  if(_auditTab==='students')body.innerHTML=auditStudents(filterBr,filterT,AD);
+  else if(_auditTab==='teachers')body.innerHTML=auditTeachers(filterBr,filterT,AD);
+  else if(_auditTab==='idle')body.innerHTML=auditIdle(filterBr,filterT,AD);
+  else if(_auditTab==='branch')body.innerHTML=auditBranch(AD);
+}
+
+// — TAB 1: Student coverage —
+function auditStudents(filterBr,filterT,AD){
+  let students=Object.values(SS);
+  if(filterBr!=='All')students=students.filter(s=>s.br===filterBr);
+  if(filterT!=='All')students=students.filter(s=>s.t===filterT);
+  students.sort((a,b)=>a.n.localeCompare(b.n));
+
+  // Per-student: which days scheduled, which car, teacher
+  const rows=students.map(s=>{
+    const needed=s.sessionsPerWeek||1;
+    const dayMap={};
+    AD.forEach(d=>{
+      CARS.forEach(car=>{
+        (SCHED[d]?.[car.id]||[]).forEach((sl_,si)=>{
+          if(!sl_)return;
+          const sids=slotStudentIds(sl_);
+          if(sids.includes(s.id)){
+            dayMap[d]=dayMap[d]||[];
+            dayMap[d].push({car:car.label,si,t:sl_.t,time:ts(slotStartMin(d,car.id,si))});
+          }
+        });
+      });
+    });
+    const scheduled=Object.keys(dayMap).length;
+    // Check pickup status per day
+    let hasAllPickups=true;
+    Object.keys(dayMap).forEach(d=>{
+      const picked=CARS.some(car=>(SCHED[d]?.[car.id]||[]).some(sl_=>sl_&&sl_.t==='pick'&&sl_.id===s.id));
+      if(!picked)hasAllPickups=false;
+    });
+    return{s,needed,scheduled,dayMap,hasAllPickups};
+  });
+
+  // Summary stats
+  const full=rows.filter(r=>r.scheduled>=r.needed).length;
+  const partial=rows.filter(r=>r.scheduled>0&&r.scheduled<r.needed).length;
+  const none=rows.filter(r=>r.scheduled===0).length;
+  const noPick=rows.filter(r=>r.scheduled>0&&!r.hasAllPickups).length;
+
+  let h=`<div class="audit-summary">
+    <div class="audit-stat"><b style="color:#059669">${full}</b><small>Fully scheduled</small></div>
+    <div class="audit-stat"><b style="color:#D97706">${partial}</b><small>Partial</small></div>
+    <div class="audit-stat"><b style="color:#DC2626">${none}</b><small>Not scheduled</small></div>
+    <div class="audit-stat"><b style="color:#7C3AED">${noPick}</b><small>Missing pickup</small></div>
+    <div class="audit-stat"><b>${rows.length}</b><small>Total students</small></div>
+  </div>`;
+  h+=`<div style="max-height:60vh;overflow:auto"><table class="audit-tbl"><thead><tr>
+    <th>Student</th><th>Teacher</th><th>Branch</th><th>Need</th><th>Sched</th><th>Status</th>`;
+  AD.forEach(d=>h+=`<th>${d}</th>`);
+  h+=`<th>Pickup</th></tr></thead><tbody>`;
+  rows.forEach(r=>{
+    const cls=r.scheduled>=r.needed?'a-ok':r.scheduled>0?'a-warn':'a-bad';
+    const pill=r.scheduled>=r.needed?'a-pill-green':r.scheduled>0?'a-pill-amber':'a-pill-red';
+    const statusLabel=r.scheduled>=r.needed?'OK':r.scheduled>0?`${r.scheduled}/${r.needed}`:'Missing';
+    h+=`<tr><td><b>${r.s.n}</b></td><td style="color:${TC[r.s.t]||'#666'}">${r.s.t}</td><td>${r.s.br}</td>
+      <td>${r.needed}</td><td class="${cls}">${r.scheduled}</td>
+      <td><span class="a-pill ${pill}">${statusLabel}</span></td>`;
+    AD.forEach(d=>{
+      const info=r.dayMap[d];
+      if(info){
+        h+=`<td style="font-size:9px">${info.map(i=>i.time+' '+i.car).join('<br>')}</td>`;
+      }else{
+        h+=`<td style="color:#D1D5DB">—</td>`;
+      }
+    });
+    h+=`<td>${r.scheduled===0?'—':r.hasAllPickups?'<span class="a-ok">✓</span>':'<span class="a-bad">✗ Missing</span>'}</td></tr>`;
+  });
+  h+=`</tbody></table></div>`;
+  return h;
+}
+
+// — TAB 2: Teacher workload —
+function auditTeachers(filterBr,filterT,AD){
+  let teachers=Object.keys(TEACHERS).filter(t=>TEACHERS[t].active!==0);
+  if(filterBr!=='All')teachers=teachers.filter(t=>{
+    const te=TEACHERS[t];return!te.branch||te.branch===filterBr;
+  });
+  if(filterT!=='All')teachers=teachers.filter(t=>t===filterT);
+  teachers.sort();
+
+  const rows=teachers.map(tname=>{
+    const te=TEACHERS[tname]||{};
+    const maxPD=(te.maxPerDay)||(SETTINGS.teacherDefaultMax||6);
+    // Find all students assigned to this teacher
+    const myStudents=Object.values(SS).filter(s=>s.t===tname);
+    const totalNeeded=myStudents.reduce((a,s)=>a+(s.sessionsPerWeek||1),0);
+    // Count sessions per day
+    const dayData={};
+    let totalSched=0;
+    AD.forEach(d=>{
+      let count=0;const studs=new Set();
+      CARS.forEach(car=>{
+        (SCHED[d]?.[car.id]||[]).forEach(sl_=>{
+          if(!sl_||sl_.t==='pick')return;
+          slotStudentIds(sl_).forEach(sid=>{
+            const s=SS[sid];
+            if(s&&s.t===tname){count++;studs.add(s.n);}
+          });
+        });
+      });
+      dayData[d]={count,studs:[...studs],maxPD,atMax:count>=maxPD};
+      totalSched+=count;
+    });
+    return{tname,te,myStudents,totalNeeded,totalSched,dayData,maxPD};
+  });
+
+  let h=`<div class="audit-summary">
+    <div class="audit-stat"><b>${teachers.length}</b><small>Active teachers</small></div>
+    <div class="audit-stat"><b>${rows.reduce((a,r)=>a+r.totalSched,0)}</b><small>Total sessions</small></div>
+    <div class="audit-stat"><b style="color:${rows.some(r=>r.totalSched<r.totalNeeded)?'#D97706':'#059669'}">${rows.filter(r=>r.totalSched<r.totalNeeded).length}</b><small>Underbooked</small></div>
+    <div class="audit-stat"><b style="color:#DC2626">${rows.filter(r=>Object.values(r.dayData).some(dd=>dd.atMax)).length}</b><small>At max on ≥1 day</small></div>
+  </div>`;
+  h+=`<div style="max-height:60vh;overflow:auto"><table class="audit-tbl"><thead><tr>
+    <th>Teacher</th><th>Branch</th><th>Students</th><th>Need</th><th>Sched</th><th>Max/day</th>`;
+  AD.forEach(d=>h+=`<th>${d}</th>`);
+  h+=`<th>Unscheduled students</th></tr></thead><tbody>`;
+  rows.forEach(r=>{
+    const schedSids=new Set();
+    AD.forEach(d=>CARS.forEach(car=>(SCHED[d]?.[car.id]||[]).forEach(sl_=>{
+      if(!sl_||sl_.t==='pick')return;
+      slotStudentIds(sl_).forEach(sid=>{if(SS[sid]?.t===r.tname)schedSids.add(sid);});
+    })));
+    const unsched=r.myStudents.filter(s=>!schedSids.has(s.id));
+    h+=`<tr><td><b style="color:${TC[r.tname]||'#666'}">${r.tname}</b></td>
+      <td>${r.te.branch||'—'}</td>
+      <td>${r.myStudents.length}</td>
+      <td>${r.totalNeeded}</td>
+      <td class="${r.totalSched>=r.totalNeeded?'a-ok':'a-warn'}">${r.totalSched}</td>
+      <td>${r.maxPD}</td>`;
+    AD.forEach(d=>{
+      const dd=r.dayData[d];
+      const cls=dd.atMax?'a-bad':dd.count>0?'a-ok':'';
+      const tip=dd.studs.length?dd.studs.join(', '):'';
+      h+=`<td class="${cls}" title="${tip}">${dd.count}${dd.atMax?' ⛔':''}</td>`;
+    });
+    h+=`<td style="font-size:9px;color:#DC2626">${unsched.length?unsched.map(s=>s.n).join(', '):'<span class="a-ok">All covered</span>'}</td></tr>`;
+  });
+  h+=`</tbody></table></div>`;
+  return h;
+}
+
+// — TAB 3: Teacher idle / waste time —
+function auditIdle(filterBr,filterT,AD){
+  // For each day × car, walk the slots and track when a teacher is IN the car
+  // but not at a drop (= idle time = waste). This happens between:
+  // - a pickup of student A (teacher done) and the next drop (same teacher) → teacher rides along uselessly
+  // - between drops when the teacher changes → old teacher waits in car during detour
+  const idleEntries=[];
+  AD.forEach(day=>{
+    CARS.forEach(car=>{
+      if(filterBr!=='All'&&!(car.branch||'').split('/').includes(filterBr))return;
+      const slots=SCHED[day]?.[car.id]||[];
+      // Build timeline of teachers in/out of car
+      let inCar=new Set(); // teachers currently in car
+      for(let si=0;si<slots.length;si++){
+        const sl_=slots[si];if(!sl_)continue;
+        const startMin=slotStartMin(day,car.id,si);
+        if(sl_.t==='pick'){
+          // After pickup, teacher is back in car — but they're done with their student
+          // If next slot is NOT their student, they're idle until returned to branch
+          const s=SS[sl_.id];if(!s)continue;
+          const teacher=s.t;
+          // Look ahead: is the next drop also for this teacher?
+          let nextDropTeacher=null;
+          for(let j=si+1;j<slots.length;j++){
+            const ns=slots[j];if(!ns)continue;
+            if(ns.t==='pick')continue;
+            const nids=slotStudentIds(ns);
+            if(nids.length)nextDropTeacher=SS[nids[0]]?.t;
+            break;
+          }
+          if(nextDropTeacher&&nextDropTeacher!==teacher){
+            // Teacher is in car but next drop isn't theirs = idle ride to branch + swap
+            const nextStart=slotStartMin(day,car.id,si+1);
+            const idleMin=nextStart-startMin;
+            if(idleMin>0){
+              idleEntries.push({day,car:car.label,teacher,fromSi:si,toSi:si+1,idleMin,reason:'Riding back to branch (teacher swap)',startMin});
+            }
+          }
+        }
+        if(sl_.t!=='pick'){
+          const sids=slotStudentIds(sl_);
+          const curTeachers=new Set(sids.map(sid=>SS[sid]?.t).filter(Boolean));
+          // Teachers in car but NOT in this drop = idle
+          for(const t of inCar){
+            if(!curTeachers.has(t)){
+              // This teacher is in the car but not dropping off — they're idle
+              idleEntries.push({day,car:car.label,teacher:t,fromSi:si-1,toSi:si,idleMin:0,reason:'In car but not assigned to this drop',startMin});
+            }
+          }
+          inCar=curTeachers;
+        }
+      }
+    });
+  });
+
+  // Filter by teacher
+  let filtered=idleEntries;
+  if(filterT!=='All')filtered=filtered.filter(e=>e.teacher===filterT);
+
+  // Also compute teacher-level summary: total idle minutes per teacher
+  const teacherIdle={};
+  filtered.forEach(e=>{
+    teacherIdle[e.teacher]=(teacherIdle[e.teacher]||0)+(e.idleMin||10);
+  });
+
+  // Summary: how many total idle events, total wasted minutes
+  const totalEvents=filtered.length;
+  const totalMin=Object.values(teacherIdle).reduce((a,b)=>a+b,0);
+
+  let h=`<div class="audit-summary">
+    <div class="audit-stat"><b style="color:${totalEvents>0?'#DC2626':'#059669'}">${totalEvents}</b><small>Idle events</small></div>
+    <div class="audit-stat"><b style="color:#D97706">${totalMin}</b><small>Est. wasted minutes</small></div>
+    <div class="audit-stat"><b>${Object.keys(teacherIdle).length}</b><small>Teachers affected</small></div>
+  </div>`;
+
+  if(!filtered.length){
+    h+=`<div style="text-align:center;padding:40px;color:#059669;font-weight:600;font-size:14px">✓ No idle time detected — all teacher rides are efficient</div>`;
+    return h;
+  }
+
+  // Teacher summary
+  h+=`<h4 style="margin:10px 0 6px;font-size:12px;color:var(--text)">Teacher idle summary</h4>`;
+  h+=`<div style="max-height:30vh;overflow:auto"><table class="audit-tbl"><thead><tr><th>Teacher</th><th>Idle events</th><th>Est. wasted time</th><th>Impact</th></tr></thead><tbody>`;
+  Object.entries(teacherIdle).sort((a,b)=>b[1]-a[1]).forEach(([t,mins])=>{
+    const events=filtered.filter(e=>e.teacher===t).length;
+    const pct=Math.min(100,Math.round(mins/60*100));
+    const cls=mins>30?'a-bad':mins>10?'a-warn':'a-ok';
+    h+=`<tr><td><b style="color:${TC[t]||'#666'}">${t}</b></td><td>${events}</td>
+      <td class="${cls}">${mins} min</td>
+      <td><div class="idle-bar"><div class="idle-fill" style="width:${pct}%;background:${mins>30?'#DC2626':mins>10?'#D97706':'#059669'}"></div></div></td></tr>`;
+  });
+  h+=`</tbody></table></div>`;
+
+  // Detail table
+  h+=`<h4 style="margin:14px 0 6px;font-size:12px;color:var(--text)">Idle events detail</h4>`;
+  h+=`<div style="max-height:35vh;overflow:auto"><table class="audit-tbl"><thead><tr><th>Day</th><th>Car</th><th>Teacher</th><th>Time</th><th>Reason</th></tr></thead><tbody>`;
+  filtered.forEach(e=>{
+    h+=`<tr><td>${e.day}</td><td>${e.car}</td><td style="color:${TC[e.teacher]||'#666'}">${e.teacher}</td>
+      <td>${ts(e.startMin)}</td><td>${e.reason}</td></tr>`;
+  });
+  h+=`</tbody></table></div>`;
+  return h;
+}
