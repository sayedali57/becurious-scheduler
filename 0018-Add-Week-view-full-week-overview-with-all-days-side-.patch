+// ===== WEEK VIEW =====
+let _wkBranch='All';
+function renderWeekView(){
+  const AD=activeDays();
+  const el=qs('week-outer');
+  const filterBr=_wkBranch;
+  // Day colors
+  const dayColors={Sun:'#7C3AED',Mon:'#2563EB',Tue:'#059669',Wed:'#D97706',Thu:'#DC2626'};
+  const dayFull={Sun:'Sunday',Mon:'Monday',Tue:'Tuesday',Wed:'Wednesday',Thu:'Thursday'};
+
+  // Filter bar
+  let h=`<div class="wk-bar">
+    <span style="font-weight:600;font-size:12px;color:var(--text)">📆 Week Overview</span>
+    <select onchange="_wkBranch=this.value;renderWeekView()">
+      <option${filterBr==='All'?' selected':''}>All</option>
+      ${[...new Set(Object.values(SS).map(s=>s.br).filter(Boolean))].sort().map(b=>`<option${b===filterBr?' selected':''}>${b}</option>`).join('')}
+    </select>
+  </div>`;
+  h+=`<div class="wk-legend">
+    <span><i style="background:#F0FDF4;border:1px solid #059669"></i> Drop</span>
+    <span><i style="background:#EFF6FF;border:1px solid #2563EB"></i> Double/Triple</span>
+    <span><i style="background:#FDF4FF;border:1px solid #9333EA"></i> Group</span>
+    <span><i style="background:#FFF7ED;border:1px solid #EA580C"></i> Pickup</span>
+  </div>`;
+
+  // Grid: days as columns
+  const cols=AD.length;
+  h+=`<div class="wk-grid" style="grid-template-columns:repeat(${cols},1fr)">`;
+
+  AD.forEach(day=>{
+    const color=dayColors[day]||'#6B7280';
+    // Gather all sessions across cars for this day
+    let dayDrops=0,dayPicks=0,dayStudents=new Set();
+
+    h+=`<div class="wk-day">`;
+    h+=`<div class="wk-day-hdr" style="background:${color}">${dayFull[day]||day}`;
+
+    // Build car sections
+    let carHtml='';
+    CARS.forEach(car=>{
+      if(filterBr!=='All'&&!(car.branch||'').split('/').includes(filterBr))return;
+      const slots=SCHED[day]?.[car.id]||[];
+      const filled=slots.filter(x=>x).length;
+      if(filled===0)return; // skip empty cars
+      const capPct=slots.length>0?Math.round(filled/slots.length*100):0;
+      const capColor=capPct>=90?'#FEE2E2':capPct>=70?'#FEF3C7':'#F0FDF4';
+
+      carHtml+=`<div class="wk-car">`;
+      carHtml+=`<div class="wk-car-hdr" style="background:${capColor}">${car.label} <span>${filled}/${slots.length} (${capPct}%)</span></div>`;
+
+      slots.forEach((sl_,si)=>{
+        if(!sl_)return; // skip empty slots in week view for compactness
+        const timeStr=ts(slotStartMin(day,car.id,si));
+        const col_=sl_.t==='pick'?'':'';
+
+        if(sl_.t==='s'){
+          const s=SS[sl_.id];if(!s)return;
+          const tc=TC[s.t]||'#6A5FA8';
+          dayDrops++;dayStudents.add(s.id);
+          carHtml+=`<div class="wk-slot wk-drop" style="border-left-color:${tc}">
+            <span class="wk-time">${timeStr}</span>
+            <span class="wk-teacher" style="color:${tc}">▼ ${s.t}</span><br>
+            <span class="wk-student">${s.n}</span>
+          </div>`;
+        }
+        else if(sl_.t==='d'){
+          const ids=sl_.ids||[];
+          const students=ids.map(id=>SS[id]).filter(Boolean);
+          dayDrops+=students.length;students.forEach(s=>dayStudents.add(s.id));
+          const label=students.length===3?'TRIPLE':'DOUBLE';
+          carHtml+=`<div class="wk-slot wk-dd">
+            <span class="wk-time">${timeStr}</span>
+            <span style="font-size:8px;font-weight:700;color:#2563EB">${label}</span><br>
+            ${students.map(s=>`<span class="wk-student" style="color:${TC[s.t]||'#666'}">▼ ${s.t}</span> ${s.n}`).join('<br>')}
+          </div>`;
+        }
+        else if(sl_.t==='g'){
+          const ids=sl_.ids||[];
+          const children=ids.map(id=>SS[id]).filter(Boolean);
+          dayDrops+=children.length;children.forEach(s=>dayStudents.add(s.id));
+          carHtml+=`<div class="wk-slot wk-grp">
+            <span class="wk-time">${timeStr}</span>
+            <span style="font-size:8px;font-weight:700;color:#9333EA">GROUP (${children.length})</span><br>
+            ${children.map(s=>`<span style="color:${TC[s.t]||'#666'};font-size:8px">● ${s.t}</span> ${s.n}`).join('<br>')}
+          </div>`;
+        }
+        else if(sl_.t==='pick'){
+          const s=SS[sl_.id];if(!s)return;
+          dayPicks++;
+          carHtml+=`<div class="wk-slot wk-pick">
+            <span class="wk-time">${timeStr}</span> ▲ ${s.n}
+          </div>`;
+        }
+      });
+      carHtml+=`</div>`;
+    });
+
+    // Day header stats
+    h+=`<small>${dayDrops} drops · ${dayPicks} pickups · ${dayStudents.size} students</small>`;
+    h+=`</div>`; // close header
+    h+=`<div class="wk-day-body">${carHtml||'<div style="padding:12px;text-align:center;color:var(--text3);font-size:10px">No sessions</div>'}</div>`;
+
+    // Day summary footer
+    const teachers=new Set();
+    CARS.forEach(car=>{
+      (SCHED[day]?.[car.id]||[]).forEach(sl_=>{
+        if(!sl_||sl_.t==='pick')return;
+        slotStudentIds(sl_).forEach(sid=>{const s=SS[sid];if(s)teachers.add(s.t);});
+      });
+    });
+    h+=`<div class="wk-day-stats"><span>👩‍🏫 ${teachers.size} teachers</span><span>🚗 ${CARS.filter(c=>{
+      if(filterBr!=='All'&&!(c.branch||'').split('/').includes(filterBr))return false;
+      return(SCHED[day]?.[c.id]||[]).some(x=>x);
+    }).length} active cars</span></div>`;
+    h+=`</div>`; // close day
+  });
+  h+=`</div>`; // close grid
+  el.innerHTML=h;
+}
+
 function switchAuditTab(tab){
   _auditTab=tab;
   document.querySelectorAll('.audit-tab').forEach(b=>b.classList.toggle('active',b.dataset.atab===tab));
