+// Remove every drop/group/pickup for students of a given branch from the
+// schedule. Used by the branch-scoped auto-scheduler's "clear first" option:
+// it wipes only the selected branch's placements, leaving other branches
+// untouched. Double/triple/group slots collapse the same way as rmFromSched.
+function clearBranchFromSched(br){
+  DAYS.forEach(d=>CARS.forEach(car=>{
+    const s=SCHED[d]?.[car.id];if(!s)return;
+    s.forEach((sl_,i)=>{
+      if(!sl_)return;
+      if(sl_.t==='s'&&SS[sl_.id]&&SS[sl_.id].br===br)s[i]=null;
+      else if(sl_.t==='d'&&Array.isArray(sl_.ids)){
+        const remaining=sl_.ids.filter(x=>!(SS[x]&&SS[x].br===br));
+        if(remaining.length===0)s[i]=null;
+        else if(remaining.length===1)s[i]={t:'s',id:remaining[0]};
+        else if(remaining.length!==sl_.ids.length){sl_.ids=remaining;ddRecomputeMetrics(sl_);}
+      }
+      else if(sl_.t==='g'&&Array.isArray(sl_.ids)){
+        sl_.ids=sl_.ids.filter(x=>!(SS[x]&&SS[x].br===br));
+        if(sl_.ids.length===0)s[i]=null;
+      }
+      else if(sl_.t==='pick'&&SS[sl_.id]&&SS[sl_.id].br===br)s[i]=null;
+    });
+  }));
+}
