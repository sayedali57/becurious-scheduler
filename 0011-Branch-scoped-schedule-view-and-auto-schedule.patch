+    else{lbl.style.display='';lbl.textContent='Viewing: '+curBr+' branch only';}
+  }
+}
+// Does this slot contain at least one student from the given branch? 'All'
+// always returns true. Pick slots fall back to their student's branch.
+function slotMatchesBranch(sl_,br){
+  if(!sl_||br==='All')return true;
+  const ids=sl_.t==='pick'?[sl_.id]:slotStudentIds(sl_);
+  return ids.some(sid=>SS[sid]&&SS[sid].br===br);
+}
 
