+  // Teacher-car affinity: once a teacher is placed on a car for a given day,
+  // strongly prefer keeping them on the same car for subsequent sessions.
+  // This eliminates wasteful branch-return trips between cars and lets
+  // teachers chain sessions back-to-back.
+  const teacherCarAffinity={};  // { 'Mon': { 'Mariya': 'car_1', ... }, ... }
+  DAYS_ACTIVE.forEach(d=>{
+    teacherCarAffinity[d]={};
+    // Prime from already-scheduled slots (manual placements)
+    CARS.forEach(car=>{
+      (SCHED[d]?.[car.id]||[]).forEach(sl_=>{
+        if(!sl_||sl_.t==='pick')return;
+        slotStudentIds(sl_).forEach(sid=>{
+          const s=SS[sid];
+          if(s&&s.t&&!teacherCarAffinity[d][s.t])teacherCarAffinity[d][s.t]=car.id;
+        });
+      });
+    });
+  });
+  const stickyBonus=-(parseInt(SETTINGS.stickyBonusKm)||15);  // strong pull toward same car
+  const stickyPenalty=Math.abs(stickyBonus)*2;                 // push away from different car
+
   function teacherCanTake(tname,day){
     const t=TEACHERS[tname];
     if(t&&!t.active)return false;
@@ -5136,14 +5160,20 @@ function runAutoSchedule(){
     // Use spread-compliant candidates first; fall back to all if none available
     // (better to schedule back-to-back than not at all)
     const pool=spread.length?spread:all;
+    const affinity=teacherCarAffinity[day]||{};
     return pool.sort((a,b)=>{
       const sa=SS[a],sb=SS[b];
       const chA=(lastTeacher&&sa.t===lastTeacher)?chainBonus:0;
       const chB=(lastTeacher&&sb.t===lastTeacher)?chainBonus:0;
+      // Teacher-car stickiness: prefer students whose teacher is already on THIS car,
+      // deprioritize students whose teacher is already on a DIFFERENT car
+      let stA=0,stB=0;
+      if(affinity[sa.t]){stA=affinity[sa.t]===car.id?stickyBonus:stickyPenalty;}
+      if(affinity[sb.t]){stB=affinity[sb.t]===car.id?stickyBonus:stickyPenalty;}
       const ca=resolveGroupCoords(sa),cb=resolveGroupCoords(sb);
       const dA=hv(pos.la,pos.ln,ca.la,ca.ln);
       const dB=hv(pos.la,pos.ln,cb.la,cb.ln);
-      return (chA+dA)-(chB+dB);
+      return (chA+stA+dA)-(chB+stB+dB);
     });
   }
 
