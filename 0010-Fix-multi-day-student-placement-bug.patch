@@ -2027,7 +2068,11 @@ function advance(d,cid,fromSi){
 
 // ===== MUTATIONS =====
 function placeIn(sid,d,cid,si){
-  rmFromSched(sid);
+  // If dragged from a placed slot, clear just that exact source. Otherwise
+  // (dragged from the pool), only scrub the target day — students with
+  // sessionsPerWeek>1 legitimately appear on multiple days, so we must not
+  // touch their slots on other days.
+  if(!_clearDragSrc(sid))rmFromSched(sid,{onlyDay:d});
   SCHED[d][cid][si]={t:'s',id:sid};
   // Auto-insert pickup in next empty slot of same car
   const slots=SCHED[d][cid];
@@ -2037,11 +2082,13 @@ function placeIn(sid,d,cid,si){
 }
 
 function placePickup(sid,d,cid,si){
-  // Remove existing pick slot for this sid
-  DAYS.forEach(dy=>CARS.forEach(car=>{
-    const s=SCHED[dy]?.[car.id];if(!s)return;
+  // Remove existing pick slot for this sid ON THIS DAY ONLY. Each day of a
+  // multi-session student has its own pickup, so we don't want to wipe the
