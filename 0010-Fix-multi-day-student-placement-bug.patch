 // ===== DRAG & DROP =====
+// Capture the slot the drag STARTED from (if any). We use this so that when a
+// student with sessionsPerWeek>1 is dragged between days, we only clear the
+// specific slot they came from — not every slot they occupy that week.
+function _captureDragSrc(target){
+  const slotEl=target&&target.closest?target.closest('[data-si]'):null;
+  if(!slotEl)return null;
+  const d=slotEl.dataset.d,cid=slotEl.dataset.cid,si=slotEl.dataset.si;
+  if(d==null||cid==null||si==null)return null;
+  return{d,cid:+cid,si:+si};
+}
 function dsDrop(e){
   dragId=this.dataset.sid||e.currentTarget.dataset.sid;dragType='drop';
+  dragSrc=_captureDragSrc(e.currentTarget);
   e.dataTransfer.setData('dtype','drop');e.dataTransfer.effectAllowed='move';
   setTimeout(()=>e.currentTarget.classList.add('dragging'),0);
 }
 function dsPick(e){
   dragId=this.dataset.sid||e.currentTarget.dataset.sid;dragType='pick';
+  dragSrc=_captureDragSrc(e.currentTarget);
   e.dataTransfer.setData('dtype','pick');e.dataTransfer.effectAllowed='move';
   setTimeout(()=>e.currentTarget.classList.add('dragging'),0);
 }
+// Clear the source slot the drag originated from. Returns true if something
+// was removed. Used by placeIn / tryPair / tryExtendPair / addToGroup so that
+// dragging a placed student to a new slot doesn't leave a duplicate behind.
+function _clearDragSrc(sid){
+  if(!dragSrc)return false;
+  const{d,cid,si}=dragSrc;
+  const sl_=SCHED[d]?.[cid]?.[si];
+  if(!sl_)return false;
+  if(sl_.t==='s'&&sl_.id===sid){SCHED[d][cid][si]=null;return true;}
+  if(sl_.t==='d'&&sl_.ids?.includes(sid)){
+    const remaining=sl_.ids.filter(x=>x!==sid);
+    if(remaining.length===0)SCHED[d][cid][si]=null;
+    else if(remaining.length===1)SCHED[d][cid][si]={t:'s',id:remaining[0]};
+    else{sl_.ids=remaining;ddRecomputeMetrics(sl_);}
+    return true;
+  }
+  if(sl_.t==='g'&&sl_.ids?.includes(sid)){
+    sl_.ids=sl_.ids.filter(x=>x!==sid);
+    if(sl_.ids.length===0)SCHED[d][cid][si]=null;
+    return true;
+  }
+  if(sl_.t==='pick'&&sl_.id===sid){SCHED[d][cid][si]=null;return true;}
+  return false;
+}
 function ev(e){e.preventDefault();}
 
 function dropCar(e,el){
   e.preventDefault();el.classList.remove('dover');if(!dragId)return;
   const cid=+el.dataset.cid;const slots=SCHED[curDay]?.[cid]||[];
-  const ei=slots.findIndex(s=>!s);if(ei<0){toast('No empty slots on this car');dragId=null;return;}
+  const ei=slots.findIndex(s=>!s);if(ei<0){toast('No empty slots on this car');dragId=null;dragSrc=null;return;}
   if(dragType==='pick')placePickup(dragId,curDay,cid,ei);else placeIn(dragId,curDay,cid,ei);
-  dragId=null;
+  dragId=null;dragSrc=null;
 }
 function dropToPool(e){
   e.preventDefault();if(!dragId)return;
-  rmFromSched(dragId);dragId=null;
+  // If the drag originated from a specific placed slot, only remove THAT
+  // slot — so students with multiple sessions per week don't lose every
+  // placement when one card is dragged back to the pool.
+  if(!_clearDragSrc(dragId))rmFromSched(dragId);
+  saveState();renderSched();renderPool();
+  dragId=null;dragSrc=null;
 }
 
