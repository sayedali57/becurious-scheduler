+  const day=SCHED[d];if(day)CARS.forEach(car=>{
+    const s=day[car.id];if(!s)return;
     s.forEach((sl_,i)=>{if(sl_&&sl_.t==='pick'&&sl_.id===sid)s[i]=null;});
-  }));
+  });
   SCHED[d][cid][si]={t:'pick',id:sid};
   advance(d,cid,si);renderSched();renderPool();saveState();
 }
@@ -2050,7 +2097,7 @@ function tryPair(sid1,sid2,d,cid,si){
   const s1=SS[sid1],s2=SS[sid2];if(!s1||!s2)return;
   const dist=hv(s1.la,s1.ln,s2.la,s2.ln);
   if(dist>3.5){toast(`${dist.toFixed(1)}km apart — too far to double-drop (max 3.5km)`);return;}
-  rmFromSched(sid1);
+  if(!_clearDragSrc(sid1))rmFromSched(sid1,{onlyDay:d});
