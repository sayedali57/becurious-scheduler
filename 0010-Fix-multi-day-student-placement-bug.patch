@@ -2068,15 +2115,22 @@ function tryExtendPair(newSid,d,cid,si){
   const lastS=SS[sl_.ids[sl_.ids.length-1]];if(!lastS)return;
   const hopKm=hv(lastS.la,lastS.ln,newS.la,newS.ln);
   if(hopKm>3.5){toast(`${hopKm.toFixed(1)}km from ${lastS.n} — too far to add (max 3.5km per leg)`);return;}
-  rmFromSched(newSid);
+  if(!_clearDragSrc(newSid))rmFromSched(newSid,{onlyDay:d});
   sl_.ids.push(newSid);
