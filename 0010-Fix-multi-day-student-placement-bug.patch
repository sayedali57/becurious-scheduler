   toast(`Triple-drop! ${SS[sl_.ids[0]].t} + ${SS[sl_.ids[1]].t} + ${newS.t} · total ${sl_.km.toFixed(1)}km`);
   advance(d,cid,si);renderSched();renderPool();saveState();
 }
 
-function rmFromSched(sid){
-  DAYS.forEach(d=>CARS.forEach(car=>{
+// Remove a student from scheduled slots. Without onlyDay this wipes every
+// occurrence across the week, which breaks sessionsPerWeek>1 because adding
+// the student to day B would silently delete their day A slot. Pass
+// {onlyDay:d} from manual drag-drop so the same student can legitimately
+// appear on multiple days — we only clean up the day we're placing into.
+function rmFromSched(sid,opts){
+  const onlyDay=opts&&opts.onlyDay;
+  const daysToScan=onlyDay?[onlyDay]:DAYS;
+  daysToScan.forEach(d=>CARS.forEach(car=>{
     const s=SCHED[d]?.[car.id];if(!s)return;
     s.forEach((sl_,i)=>{
       if(!sl_)return;
@@ -2131,7 +2185,8 @@ function addToGroup(sid,d,cid,si){
   if(!sl_||sl_.t!=='g'){toast('Not a group slot');return;}
   if(sl_.ids.length>=7){toast('Group is full (7/7)');return;}
   if(sl_.ids.includes(sid)){toast('Child already in this group');return;}
-  rmFromSched(sid); // remove from elsewhere first
+  // Only scrub the source slot (if any) or target day — leaves other days' slots alone.
+  if(!_clearDragSrc(sid))rmFromSched(sid,{onlyDay:d});
   sl_.ids.push(sid);
   // Auto-add pickup for this child
   const slots=SCHED[d][cid];
@@ -2157,7 +2212,7 @@ function grpLeave(el){el.classList.remove('doverg');}
 function grpDrop(e,el,d,cid,si){
   e.preventDefault();e.stopPropagation();el.classList.remove('doverg');
   if(!dragId||dragType!=='drop')return;
-  addToGroup(dragId,d,cid,si);dragId=null;
+  addToGroup(dragId,d,cid,si);dragId=null;dragSrc=null;
