+// ===== TEACHER WHATSAPP NOTIFICATIONS =====
+// Build a WhatsApp-friendly weekly schedule message for a single teacher.
+// Format mirrors buildParentMessage() so tone stays consistent across the app.
+function buildTeacherMessage(tname){
+  const t=TEACHERS[tname];if(!t)return null;
+  const sessions=[];
+  forEachScheduledSlot(({d,cid,si,sid,sl_})=>{
+    const s=SS[sid];if(!s||s.t!==tname)return;
+    sessions.push({d,cid,si,sid,s,startM:slotStartMin(d,cid,si),car:CARS.find(c=>c.id===cid)});
+  });
+  if(!sessions.length)return null;
+  const dayOrder={Sun:-1,Mon:0,Tue:1,Wed:2,Thu:3};
+  const dayFull={Sun:'Sunday',Mon:'Monday',Tue:'Tuesday',Wed:'Wednesday',Thu:'Thursday'};
+  sessions.sort((a,b)=>(dayOrder[a.d]-dayOrder[b.d])||(a.startM-b.startM));
+  const firstName=tname.split(' ')[0];
+  const header=`Salam\n\nHi ${firstName}, here is your BeCurious home visit schedule for the week (${sessions.length} session${sessions.length===1?'':'s'}):`;
+  // Group lines by day so the message reads cleanly on WhatsApp
+  const byDay={};
+  sessions.forEach(x=>{(byDay[x.d]=byDay[x.d]||[]).push(x);});
+  const lines=[];
+  Object.keys(byDay).sort((a,b)=>dayOrder[a]-dayOrder[b]).forEach(d=>{
+    lines.push(`\n*${dayFull[d]||d}*`);
+    byDay[d].forEach(x=>{
+      lines.push(`- ${ts(x.startM)} — ${x.s.n}${x.car?` (${x.car.label})`:''}`);
+    });
+  });
+  const footer=`\n\nPlease be ready 15 minutes before the first pickup each day. Reply here if any issues regarding the schedule.\n\n— BeCurious`;
+  return header+'\n'+lines.join('\n')+footer;
+}
+function sendTeacherWhatsApp(tname){
+  const t=TEACHERS[tname];if(!t){toast('Teacher not found');return;}
+  if(!t.phone){toast('No phone saved for '+tname+' — add it in the Teachers table first');return;}
+  const msg=buildTeacherMessage(tname);
+  if(!msg){toast(tname+' has no scheduled sessions this week');return;}
+  const phone=String(t.phone).replace(/[^0-9]/g,'');
+  const url='https://wa.me/'+phone+'?text='+encodeURIComponent(msg);
+  window.open(url,'_blank');
+}
+function sendAllTeacherMessages(){
+  // Only teachers with phone AND at least one scheduled session this week
+  const eligible=[];
+  const sessionsByTeacher={};
+  forEachScheduledSlot(({sid})=>{
+    const s=SS[sid];if(!s||!s.t)return;
+    sessionsByTeacher[s.t]=(sessionsByTeacher[s.t]||0)+1;
+  });
+  Object.keys(TEACHERS).forEach(name=>{
+    const t=TEACHERS[name];
+    if(t&&t.phone&&sessionsByTeacher[name])eligible.push(name);
+  });
+  if(!eligible.length){toast('No teachers with phone and scheduled sessions');return;}
+  if(!confirm(`Open ${eligible.length} WhatsApp tab(s) — one per teacher?\n\nYour browser may block pop-ups — allow them for this site first.`))return;
+  let opened=0;
+  eligible.forEach((name,i)=>{
+    setTimeout(()=>{sendTeacherWhatsApp(name);opened++;if(opened===eligible.length)toast(`${opened} teacher WhatsApp tab(s) opened`);},i*350);
+  });
+}
