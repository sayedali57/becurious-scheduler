+// ===== COMPLETION EDITING =====
+// Snapshot-based undo for bulk attendance changes.
+function _snapshotAttend(){return JSON.parse(JSON.stringify(ATTEND));}
+function _restoreAttend(snap){ATTEND=snap;saveState();if(typeof renderSched==='function')renderSched();if(typeof renderReports==='function'&&qs('reportsmodal')?.style.display==='flex')renderReports();}
+function _withAttendSnapshot(label,fn){
+  const snap=_snapshotAttend();
+  let n=0;
+  try{n=fn()||0;}catch(e){console.error(e);toast('Action failed: '+e.message);return;}
+  saveState();
+  if(typeof renderSched==='function')renderSched();
+  if(qs('reportsmodal')?.style.display==='flex'&&typeof renderReports==='function')renderReports();
+  if(n===0){toast('Nothing changed');return;}
+  toastUndo(label.replace('{n}',n),()=>{_restoreAttend(snap);toast('Reverted');},10000);
+}
+// Bulk: mark every unmarked session this week as completed.
+function bulkMarkAllCompleted(){
+  const wk=activeWeekKey();
+  _withAttendSnapshot(`Marked {n} sessions as completed`,()=>{
+    let n=0;
+    forEachScheduledSlot(({d,cid,si,sid})=>{
+      const st=getAtt(d,cid,si,sid,wk);
+      if(st==='unmarked'||st==null||st===''){setAtt(d,cid,si,sid,'completed');n++;}
+    });
+    return n;
+  });
+}
+// Bulk: clear every attendance mark this week (keeps schedule slots intact).
+function bulkResetWeek(){
+  const wk=activeWeekKey();
+  if(!confirm(`Clear every attendance mark for ${wk}? Scheduled sessions are kept; only the ✓ ✗ ⚠ marks are reset. You can undo for 10 seconds.`))return;
+  _withAttendSnapshot(`Reset {n} attendance marks`,()=>{
+    let n=0;
+    forEachScheduledSlot(({d,cid,si,sid})=>{
+      const st=getAtt(d,cid,si,sid,wk);
+      if(st&&st!=='unmarked'){setAtt(d,cid,si,sid,'');n++;}
+    });
+    return n;
+  });
+}
+// Per-row: mark one student's unmarked sessions this week as completed.
+function markStudentAllDone(sid){
+  const s=SS[sid];if(!s)return;
+  const wk=activeWeekKey();
+  _withAttendSnapshot(`Marked {n} of ${s.n}'s sessions completed`,()=>{
+    let n=0;
+    forEachScheduledSlot(({d,cid,si,sid:slotSid})=>{
+      if(slotSid!==sid)return;
+      const st=getAtt(d,cid,si,sid,wk);
+      if(st==='unmarked'||st==null||st===''){setAtt(d,cid,si,sid,'completed');n++;}
+    });
+    return n;
+  });
+}
+// Per-row: reset one student's attendance this week.
+function resetStudentWeek(sid){
+  const s=SS[sid];if(!s)return;
+  const wk=activeWeekKey();
+  _withAttendSnapshot(`Reset {n} of ${s.n}'s marks`,()=>{
+    let n=0;
+    forEachScheduledSlot(({d,cid,si,sid:slotSid})=>{
+      if(slotSid!==sid)return;
+      const st=getAtt(d,cid,si,sid,wk);
+      if(st&&st!=='unmarked'){setAtt(d,cid,si,sid,'');n++;}
+    });
+    return n;
+  });
+}
