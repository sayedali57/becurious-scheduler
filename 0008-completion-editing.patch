+// ===== SHARED WEEK PICKER (schedule view + reports stay in sync) =====
+// Called by the schedule-view dropdown and the completion report's per-row actions.
+function setSelectedWeek(wk){
+  _rptWeek=wk||currentWeekKey();
+  // Mirror to both dropdowns so they never drift
+  const rw=qs('rpt-week');if(rw)rw.value=_rptWeek;
+  const sw=qs('sched-week');if(sw)sw.value=_rptWeek;
+  updateSchedWeekBanner();
+  // Re-render the schedule so each slot's attendance row picks up the new week
+  renderSched();
+  // If reports view is open, re-render it too
+  if(qs('reportsmodal')?.style.display==='flex'&&typeof renderReports==='function')renderReports();
+}
+// Populate the schedule-view week picker (and keep the banner consistent).
+function populateSchedWeekPicker(){
+  const sel=qs('sched-week');if(!sel)return;
+  const weeks=[];
+  for(let i=-8;i<=2;i++)weeks.push(weekKeyOffset(i));
+  Object.keys(ATTEND).forEach(w=>{if(!weeks.includes(w))weeks.push(w);});
+  weeks.sort();
+  const cur=currentWeekKey();
+  const active=_rptWeek||cur;
+  sel.innerHTML=weeks.map(w=>{
+    const label=w+(w===cur?' (current)':'');
+    return `<option value="${w}"${w===active?' selected':''}>${label}</option>`;
+  }).join('');
+  updateSchedWeekBanner();
+}
+// Show/hide the orange 'you are editing a past week' banner in the schedule view.
+function updateSchedWeekBanner(){
+  const banner=qs('sched-week-banner');if(!banner)return;
+  const cur=currentWeekKey();
+  const active=_rptWeek||cur;
+  if(active===cur){
+    banner.style.display='none';
+  }else{
+    const past=active<cur;
+    banner.style.display='block';
+    banner.style.background=past?'#FEF3CD':'#DBEAFE';
+    banner.style.borderBottomColor=past?'#F59E0B':'#3B82F6';
+    banner.style.color=past?'#92400E':'#1E3A8A';
+    banner.textContent=`⚠ You are editing attendance for ${active} ${past?'(past week)':'(future week)'} — every ✓ ✗ ⚠ click affects this week, not the current one. Click to return: `;
+    const link=document.createElement('a');
+    link.href='#';link.textContent=cur+' (current)';
+    link.style.cssText='color:inherit;text-decoration:underline;margin-left:4px;font-weight:700';
+    link.onclick=function(ev){ev.preventDefault();setSelectedWeek(cur);};
+    banner.appendChild(link);
+  }
+}
