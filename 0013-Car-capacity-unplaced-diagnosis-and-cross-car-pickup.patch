+// Diagnose why a student still has unscheduled sessions.
+// Returns a short human-readable reason string (or '' if no issue detected).
+function diagnoseUnplaced(s){
+  const reasons=[];
+  // 1. Teacher inactive
+  const t=TEACHERS[s.t];
+  if(t&&!t.active){reasons.push(`Teacher ${s.t} is inactive`);return reasons.join('; ');}
+  // 2. No car serves their branch
+  const hasCar=CARS.some(c=>{
+    if(!SETTINGS.sameBranchOnly)return true;
+    return(c.branch||'').split('/').includes(s.br);
+  });
+  if(!hasCar){reasons.push(`No car covers ${s.br} branch`);return reasons.join('; ');}
+  // 3. Teacher day availability — count how many active days teacher works
+  const teacherDays=activeDays().filter(d=>!t||!t.days||t.days[d]);
+  if(!teacherDays.length){reasons.push(`${s.t} has no active days`);return reasons.join('; ');}
+  // 4. All available car slots full on teacher's days
+  const maxPD=(t&&t.maxPerDay)||(SETTINGS.teacherDefaultMax||6);
+  let allFull=true, teacherMaxed=true;
+  teacherDays.forEach(d=>{
+    // Count teacher's existing sessions this day
+    let teacherCount=0;
+    CARS.forEach(car=>(SCHED[d]?.[car.id]||[]).forEach(sl_=>{
+      if(!sl_)return;
+      slotStudentIds(sl_).forEach(sid=>{if(SS[sid]?.t===s.t)teacherCount++;});
+    }));
+    if(teacherCount<maxPD)teacherMaxed=false;
+    // Check if any matching car has empty slots
+    CARS.forEach(car=>{
+      if(SETTINGS.sameBranchOnly&&!(car.branch||'').split('/').includes(s.br))return;
+      if((SCHED[d]?.[car.id]||[]).some(x=>!x))allFull=false;
+    });
+  });
+  if(teacherMaxed)reasons.push(`${s.t} at max (${maxPD}/day) on all available days`);
+  if(allFull&&!teacherMaxed)reasons.push(`All ${s.br} car slots full`);
+  if(!reasons.length)reasons.push('Likely ran out of slots — try adding more slots or cars');
+  return reasons.join('; ');
+}
