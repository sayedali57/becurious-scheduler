 // ===== TOAST =====
 function toast(msg){const t=document.createElement('div');t.className='toast';t.textContent=msg;document.body.appendChild(t);setTimeout(()=>t.remove(),3500);}
+// Toast with an Undo link on the right side. onUndo runs if user clicks before timeout.
+function toastUndo(msg,onUndo,ms){
+  const t=document.createElement('div');
+  t.className='toast';
+  t.style.cursor='default';
+  t.innerHTML='';
+  const span=document.createElement('span');span.textContent=msg+'  ';
+  const btn=document.createElement('span');
+  btn.textContent='↶ Undo';
+  btn.style.cssText='color:#FCA5A5;font-weight:700;cursor:pointer;text-decoration:underline;margin-left:8px';
+  let used=false;
+  btn.onclick=function(ev){ev.stopPropagation();if(used)return;used=true;onUndo&&onUndo();t.remove();};
+  t.appendChild(span);t.appendChild(btn);
+  document.body.appendChild(t);
+  setTimeout(()=>{if(!used)t.remove();},ms||10000);
+}
 
 // ===== START =====
 init();
