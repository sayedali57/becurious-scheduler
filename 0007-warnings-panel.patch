+    // No-single-fix types: Jump + Delete
+    return `<button class="wf-jump" onclick="jumpToSlot(${args})">👁 Jump</button>`+
+           `<button class="wf-del" onclick="fixDeleteSlot(${args})">🗑 Delete slot</button>`;
+  }
+  body.innerHTML=days.map(d=>`
+    <div style="padding:10px 16px 4px 16px;font-size:10px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:0.5px;background:#FAFAFA;border-bottom:1px solid var(--border);position:sticky;top:0">${dayFull[d]||d} <span style="color:var(--text3);font-weight:400">(${byDay[d].length})</span></div>
+    ${byDay[d].map(w=>`
+      <div class="wf-row" style="padding:10px 16px;border-bottom:1px solid #F0F0F0;display:flex;gap:10px;align-items:flex-start">
+        <div style="width:6px;height:6px;border-radius:50%;background:${sev[w.type]||'#999'};margin-top:6px;flex-shrink:0"></div>
+        <div style="flex:1;min-width:0">
+          <div style="font-size:9px;color:${sev[w.type]||'#999'};font-weight:700;text-transform:uppercase;letter-spacing:0.4px">${typeLabel[w.type]||w.type} · ${esc(w.car?.label||'')}</div>
+          <div style="font-size:11px;color:var(--text);margin-top:2px;line-height:1.35">${esc(w.msg)}</div>
+        </div>
+        <div style="display:flex;gap:4px;flex-shrink:0;align-items:center">${btnHtml(w)}</div>
+      </div>
+    `).join('')}
+  `).join('');
+  // Header counts
+  qs('warnpanel-count').textContent=list.length;
+  modal.style.display='flex';
+}
