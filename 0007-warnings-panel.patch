+function slotWarnings(d,cid,si){
+  return slotWarningsStructured(d,cid,si).map(w=>'⚠ '+w.msg);
+}
+// Walk the entire SCHED and return every warning across every slot, tagged with d/cid/si.
+function allScheduleWarnings(){
+  const out=[];
+  activeDays().forEach(d=>{
+    CARS.forEach(car=>{
+      const slots=SCHED[d]?.[car.id]||[];
+      slots.forEach((sl_,si)=>{
+        if(!sl_)return;
+        slotWarningsStructured(d,car.id,si).forEach(w=>{
+          out.push({d,cid:car.id,si,car,...w});
+        });
+      });
+    });
+  });
+  return out;
+}
+// ===== WARNING FIX HANDLERS =====
+// Each fix takes a snapshot of SCHED BEFORE mutating so the user can undo within ~10s.
+// After every fix we re-render + save and re-open the panel so the list refreshes.
+function _snapshotSched(){return JSON.parse(JSON.stringify(SCHED));}
+function _restoreSched(snap){SCHED=snap;renderSched();renderPool();saveState();if(qs('warnpanel')?.style.display==='flex')showWarningsPanel();}
+function _withSnapshot(label,fn){
+  const snap=_snapshotSched();
+  try{fn();}catch(e){console.error(e);toast('Fix failed: '+e.message);return;}
+  renderSched();renderPool();saveState();
+  if(qs('warnpanel')?.style.display==='flex')showWarningsPanel(); // refresh the panel
+  toastUndo(label,()=>{_restoreSched(snap);toast('Reverted');},10000);
+}
+// Fix an early-pickup by deleting the misplaced pickup and re-inserting it in the first
+// empty slot AFTER the drop on the same day/car. If no empty slot is available we push one.
+function fixEarlyPickup(d,cid,si){
+  _withSnapshot('Pickup shifted to correct time',()=>{
+    const sl_=SCHED[d]?.[cid]?.[si];if(!sl_||sl_.t!=='pick')return;
+    const sid=sl_.id;
+    const info=findDropInfo(sid);
+    if(!info){toast('No matching drop found');return;}
+    // Null out the wrong pickup first
+    SCHED[d][cid][si]=null;
+    // Find the drop slot index on the same day+car (pickup must be same-day same-car to the drop)
+    if(info.d!==d||info.cid!==cid){
+      // Different day/car drop — just drop the pickup, user will re-place manually
+      toast('Drop is on a different day/car — pickup removed, please re-add manually');
+      return;
+    }
+    const slots=SCHED[d][cid];
+    let target=-1;
+    for(let i=info.si+1;i<slots.length;i++){if(!slots[i]){target=i;break;}}
+    if(target===-1){
+      // Append a new trailing slot
+      slots.push({t:'pick',id:sid});
+    }else{
+      slots[target]={t:'pick',id:sid};
+    }
+  });
+}
+// Delete an orphaned pickup slot (no matching drop anywhere).
+function fixOrphanedPickup(d,cid,si){
+  _withSnapshot('Orphaned pickup removed',()=>{
+    const sl_=SCHED[d]?.[cid]?.[si];if(!sl_||sl_.t!=='pick')return;
+    SCHED[d][cid][si]=null;
+  });
+}
+// Insert an auto-pickup after a drop whose teacher is stranded.
+function fixStrandedTeacher(d,cid,si,sid){
+  _withSnapshot('Auto-pickup inserted',()=>{
+    const slots=SCHED[d]?.[cid];if(!slots)return;
+    // Already has a pickup? bail
+    if(findPickSlot(sid))return;
+    let target=-1;
+    for(let i=si+1;i<slots.length;i++){if(!slots[i]){target=i;break;}}
+    if(target===-1){slots.push({t:'pick',id:sid});}
+    else{slots[target]={t:'pick',id:sid};}
+  });
+}
+// Delete a slot (drop / double / group / pickup) — students return to the pool automatically
+// because renderPool reads from poolEntries() which scans SCHED.
+function fixDeleteSlot(d,cid,si){
+  _withSnapshot('Slot deleted — student(s) back to pool',()=>{
+    const slots=SCHED[d]?.[cid];if(!slots||!slots[si])return;
+    slots[si]=null;
+  });
+}
+// Jump to the slot in the schedule view: switch to the day, close the panel, flash the slot.
+function jumpToSlot(d,cid,si){
+  qs('warnpanel').style.display='none';
+  curDay=d;
+  if(typeof renderDayTabs==='function')renderDayTabs();
+  renderSched();
+  // After a tick, find and flash the slot element
+  setTimeout(()=>{
+    const el=document.getElementById('sl-'+d+'-'+cid+'-'+si);
+    if(el){
+      el.scrollIntoView({behavior:'smooth',block:'center'});
+      el.style.transition='box-shadow 400ms';
+      const orig=el.style.boxShadow;
+      el.style.boxShadow='0 0 0 3px #DC2626';
+      setTimeout(()=>{el.style.boxShadow=orig;},1800);
+    }
+  },120);
+}
+// ===== WARNINGS PANEL (central dashboard with one-click fixes) =====
