+// ===== PIPELINE / CRM ENGINE (SOP 4.6.4) =====
+const PL_STAGES=[
+  {id:'inquiry',label:'Inquiry',icon:'📨',color:'#2563EB'},
+  {id:'tour_booked',label:'Tour Booked',icon:'📅',color:'#7C3AED'},
+  {id:'toured',label:'Toured',icon:'🏫',color:'#0891B2'},
+  {id:'offer_made',label:'Offer Made',icon:'📝',color:'#D97706'},
+  {id:'enrolled',label:'Enrolled',icon:'✅',color:'#059669'},
+  {id:'retained',label:'Retained / Referred',icon:'⭐',color:'#9333EA'},
+  {id:'lost',label:'Lost',icon:'❌',color:'#DC2626'}
+];
+const PL_SOURCES=['Walk-in','WhatsApp','Instagram','Referral','Website','Phone','Other'];
+const PL_TOUR_OUTCOMES=['strong','undecided','unlikely'];
+const PL_LOST_REASONS=['Pricing','Location','Schedule conflict','Competitor','No response','Other'];
+const PL_STALE_DAYS=14;
+const PL_MAX_CONTACTS=3;
+
+// Pipeline state — synced alongside SS/SCHED/etc
+let PIPELINE={};  // {[leadId]: leadObj}
+let _plSearch='';
+let _plDragId=null;
+
+function plId(){return 'lead_'+Date.now()+'_'+Math.random().toString(36).slice(2,7);}
+
+function newLead(overrides){
+  const id=plId();
+  const now=new Date().toISOString();
+  return Object.assign({
+    id,
+    familyName:'',
+    childName:'',
+    childAge:'',
+    phone:'',
+    email:'',
+    source:'Walk-in',
+    branch:'Salam',
+    stage:'inquiry',
+    tourDate:'',
+    tourOutcome:'',
+    offerNote:'',
+    lostReason:'',
+    lostNote:'',
+    contactCount:0,
+    notes:'',
+    log:[],         // [{ts,type:'outgoing'|'incoming'|'note',text}]
+    createdAt:now,
+    updatedAt:now,
+    stageEnteredAt:now
+  },overrides||{},{id});
+}
+
+function plLeadsByStage(stageId){
+  return Object.values(PIPELINE).filter(l=>l.stage===stageId)
+    .filter(l=>{
+      if(!_plSearch)return true;
+      const q=_plSearch.toLowerCase();
+      return (l.familyName||'').toLowerCase().includes(q)||(l.childName||'').toLowerCase().includes(q)||(l.phone||'').includes(q);
+    })
+    .sort((a,b)=>new Date(b.updatedAt)-new Date(a.updatedAt));
+}
+
+function plDaysSince(isoStr){
+  if(!isoStr)return 999;
+  return Math.floor((Date.now()-new Date(isoStr).getTime())/86400000);
+}
+
+function plIsStale(lead){
+  if(lead.stage==='enrolled'||lead.stage==='retained'||lead.stage==='lost')return false;
+  return plDaysSince(lead.stageEnteredAt)>=PL_STALE_DAYS;
+}
+
+function plIsHot(lead){
+  return plDaysSince(lead.updatedAt)<=2;
+}
+
+function plSavePipeline(){
+  saveState();
+}
+
+// ---- RENDER KANBAN ----
+function renderPipeline(){
+  const el=qs('pipeline-outer');
+  if(!el)return;
+  const total=Object.keys(PIPELINE).length;
+  const staleCount=Object.values(PIPELINE).filter(plIsStale).length;
+
+  let h='<div class="pl-toolbar">';
+  h+='<span class="pl-title">🔗 Admission Pipeline</span>';
+  h+='<span class="pl-stat">Total: <b>'+total+'</b></span>';
+  if(staleCount>0) h+='<span class="pl-stat" style="color:#DC2626;border-color:#FCA5A5">Stale: <b style="color:#DC2626">'+staleCount+'</b></span>';
+  // Weekly numbers
+  const now=new Date();
+  const weekAgo=new Date(now.getTime()-7*86400000).toISOString();
+  const wkInq=Object.values(PIPELINE).filter(l=>l.createdAt>=weekAgo).length;
+  const wkTour=Object.values(PIPELINE).filter(l=>l.stage==='tour_booked'&&l.stageEnteredAt>=weekAgo).length;
+  const wkTouredN=Object.values(PIPELINE).filter(l=>l.stage==='toured'&&l.stageEnteredAt>=weekAgo).length;
+  const wkOffer=Object.values(PIPELINE).filter(l=>l.stage==='offer_made'&&l.stageEnteredAt>=weekAgo).length;
+  const wkEnrolled=Object.values(PIPELINE).filter(l=>l.stage==='enrolled'&&l.stageEnteredAt>=weekAgo).length;
+  h+='<span class="pl-stat" title="5 Weekly Numbers (SOP 4.6.4)">This week: <b>'+wkInq+'</b> inq · <b>'+wkTour+'</b> booked · <b>'+wkTouredN+'</b> toured · <b>'+wkOffer+'</b> offers · <b>'+wkEnrolled+'</b> enrolled</span>';
+  h+='<div style="flex:1"></div>';
+  h+='<input class="pl-search" placeholder="Search leads..." value="'+esc(_plSearch)+'" oninput="_plSearch=this.value;renderPipeline()">';
+  h+='<button class="pl-add-btn" onclick="openPlModal()">+ New Lead</button>';
+  h+='</div>';
+
+  // Kanban board
+  h+='<div class="pl-board">';
+  PL_STAGES.forEach(stg=>{
+    const leads=plLeadsByStage(stg.id);
+    h+='<div class="pl-col">';
+    h+='<div class="pl-col-hdr"><span class="pl-col-title">'+stg.icon+' '+stg.label+'</span><span class="pl-col-cnt">'+leads.length+'</span></div>';
+    h+='<div class="pl-col-body" data-stage="'+stg.id+'" ondragover="plDragOver(event)" ondragleave="plDragLeave(event)" ondrop="plDrop(event,\''+stg.id+'\')">';
+    leads.forEach(lead=>{
+      const stale=plIsStale(lead);
+      const hot=plIsHot(lead)&&!stale;
+      const days=plDaysSince(lead.stageEnteredAt);
+      h+='<div class="pl-card'+(stale?' stale':'')+'" draggable="true" ondragstart="plDragStart(event,\''+lead.id+'\')" ondragend="plDragEnd(event)" onclick="openPlModal(\''+lead.id+'\')">';
+      if(stale) h+='<span class="pl-card-stale">⚠ '+days+'d stale</span>';
+      else if(hot) h+='<span class="pl-card-hot">🔥 new</span>';
+      h+='<div class="pl-card-name">'+esc(lead.familyName||'Unnamed')+'</div>';
+      h+='<div class="pl-card-child">'+esc(lead.childName||'')+(lead.childAge?' ('+esc(lead.childAge)+')':'')+'</div>';
+      h+='<div class="pl-card-meta">';
+      if(lead.source) h+='<span class="pl-src">'+esc(lead.source)+'</span>';
+      h+='<span>'+days+'d in stage</span>';
+      if(lead.contactCount>0) h+='<span>'+lead.contactCount+'/'+PL_MAX_CONTACTS+' contacts</span>';
+      h+='</div>';
+      h+='</div>';
+    });
+    h+='</div></div>';
+  });
+  h+='</div>';
+  el.innerHTML=h;
+}
+
+// ---- DRAG & DROP ----
+function plDragStart(e,leadId){
+  _plDragId=leadId;
+  e.dataTransfer.effectAllowed='move';
+  e.target.classList.add('dragging');
+}
+function plDragEnd(e){
+  _plDragId=null;
+  e.target.classList.remove('dragging');
+  document.querySelectorAll('.pl-col-body.drag-over').forEach(el=>el.classList.remove('drag-over'));
+}
+function plDragOver(e){
+  e.preventDefault();
+  e.dataTransfer.dropEffect='move';
+  e.currentTarget.classList.add('drag-over');
+}
+function plDragLeave(e){
+  e.currentTarget.classList.remove('drag-over');
+}
+function plDrop(e,newStage){
+  e.preventDefault();
