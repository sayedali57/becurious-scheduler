From 08c46a2f33063b3480975bf35d64f9456c908047 Mon Sep 17 00:00:00 2001
From: Saleh <saleh@emergegcc.com>
Date: Sun, 12 Apr 2026 15:57:28 +0300
Subject: [PATCH] fix: week view legend toggles now clickable (remove
 label/checkbox double-click bug)

- Replace <label>+<input checkbox> with plain <span> onclick handlers
- Label elements caused double-fire (label click + checkbox click) toggling twice = no visible effect
- 32/32 smoke tests pass
---
 public/scheduler.html | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/public/scheduler.html b/public/scheduler.html
index 05ed431..0b7c581 100644
--- a/public/scheduler.html
+++ b/public/scheduler.html
@@ -3262,10 +3262,10 @@ function renderWeekView(){
     </select>
   </div>`;
   h+=`<div class="wk-legend">
-    <label class="wk-filter-btn${_wkFilter.drop?' active':''}" onclick="_wkFilter.drop=!_wkFilter.drop;renderWeekView()"><i style="background:#F0FDF4;border:1px solid #059669"></i><input type="checkbox" ${_wkFilter.drop?'checked':''} style="display:none"> Drop</label>
-    <label class="wk-filter-btn${_wkFilter.dd?' active':''}" onclick="_wkFilter.dd=!_wkFilter.dd;renderWeekView()"><i style="background:#EFF6FF;border:1px solid #2563EB"></i><input type="checkbox" ${_wkFilter.dd?'checked':''} style="display:none"> Double/Triple</label>
-    <label class="wk-filter-btn${_wkFilter.grp?' active':''}" onclick="_wkFilter.grp=!_wkFilter.grp;renderWeekView()"><i style="background:#FDF4FF;border:1px solid #9333EA"></i><input type="checkbox" ${_wkFilter.grp?'checked':''} style="display:none"> Group</label>
-    <label class="wk-filter-btn${_wkFilter.pick?' active':''}" onclick="_wkFilter.pick=!_wkFilter.pick;renderWeekView()"><i style="background:#FFF7ED;border:1px solid #EA580C"></i><input type="checkbox" ${_wkFilter.pick?'checked':''} style="display:none"> Pickup</label>
+    <span class="wk-filter-btn${_wkFilter.drop?' active':''}" onclick="_wkFilter.drop=!_wkFilter.drop;renderWeekView()"><i style="background:#F0FDF4;border:1px solid #059669"></i> Drop</span>
+    <span class="wk-filter-btn${_wkFilter.dd?' active':''}" onclick="_wkFilter.dd=!_wkFilter.dd;renderWeekView()"><i style="background:#EFF6FF;border:1px solid #2563EB"></i> Double/Triple</span>
+    <span class="wk-filter-btn${_wkFilter.grp?' active':''}" onclick="_wkFilter.grp=!_wkFilter.grp;renderWeekView()"><i style="background:#FDF4FF;border:1px solid #9333EA"></i> Group</span>
+    <span class="wk-filter-btn${_wkFilter.pick?' active':''}" onclick="_wkFilter.pick=!_wkFilter.pick;renderWeekView()"><i style="background:#FFF7ED;border:1px solid #EA580C"></i> Pickup</span>
   </div>`;
 
   // Grid: days as columns
